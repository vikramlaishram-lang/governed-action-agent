{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decision_envelope_v0.2.schema.json",
  "title": "Decision Envelope v0.2",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "runtime_id",
    "proposal_id",
    "proposal_hash",
    "agent_id",
    "agent_output_mode",
    "agent_output_mode_basis",
    "execution_authority_claimed",
    "proposal_readiness_score",
    "internal_trace_id",
    "proposed_action",
    "normalized_action",
    "normalized_action_hash",
    "consequence_classification",
    "evidence_references",
    "evidence_gap_summary",
    "policy_version",
    "policy_hash",
    "decision_engine_version",
    "decision",
    "decision_basis",
    "decision_reason",
    "review_status",
    "reviewer_authority_id",
    "reviewer_role",
    "approval_token_id",
    "approval_scope",
    "approval_expiry",
    "approval_valid",
    "approval_errors",
    "execution_status",
    "outcome_status",
    "tamper_evidence_mode",
    "previous_record_hash",
    "record_hash"
  ],
  "properties": {
    "schema_version": { "const": "decision_envelope_v0.2" },
    "created_at": { "type": "string" },
    "runtime_id": { "type": "string" },
    "proposal_id": { "type": "string" },
    "proposal_hash": { "type": "string" },
    "agent_id": { "type": "string" },
    "agent_output_mode": { "type": "string" },
    "agent_output_mode_basis": { "type": "string" },
    "execution_authority_claimed": { "type": "boolean" },
    "proposal_readiness_score": { "type": "number" },
    "internal_trace_id": { "type": "string" },
    "proposed_action": { "type": "string" },
    "normalized_action": { "type": "string" },
    "normalized_action_hash": { "type": "string" },
    "consequence_classification": { "type": "string" },
    "evidence_references": { "type": "array", "items": { "type": "string" } },
    "evidence_gap_summary": { "type": "array", "items": { "type": "string" } },
    "policy_version": { "type": "string" },
    "policy_hash": { "type": "string" },
    "decision_engine_version": { "type": "string" },
    "decision": { "enum": ["ALLOW", "DENY", "REQUEST_REVIEW"] },
    "decision_basis": { "type": "string" },
    "decision_reason": { "type": "string" },
    "review_status": { "type": "string" },
    "reviewer_authority_id": { "type": ["string", "null"] },
    "reviewer_role": { "type": ["string", "null"] },
    "approval_token_id": { "type": ["string", "null"] },
    "approval_scope": { "type": ["string", "null"] },
    "approval_expiry": { "type": ["string", "null"] },
    "approval_valid": { "type": "boolean" },
    "approval_errors": { "type": "array", "items": { "type": "string" } },
    "execution_status": { "enum": ["PENDING", "EXECUTED", "NOT_EXECUTED"] },
    "outcome_status": { "enum": ["PENDING", "SUCCESS", "BLOCKED", "PENDING_REVIEW", "FAILED"] },
    "tamper_evidence_mode": { "type": "string" },
    "previous_record_hash": { "type": ["string", "null"] },
    "record_hash": { "type": "string" }
  },
  "additionalProperties": false
}
