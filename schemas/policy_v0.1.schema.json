{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy_v0.1.schema.json",
  "title": "Policy v0.1",
  "type": "object",
  "required": ["schema_version", "policy_version", "decision_engine_version", "default_decision", "rules"],
  "properties": {
    "schema_version": { "const": "policy_v0.1" },
    "policy_version": { "type": "string" },
    "decision_engine_version": { "type": "string" },
    "default_decision": { "enum": ["ALLOW", "DENY", "REQUEST_REVIEW"] },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["decision", "review_required", "review_can_override"],
        "properties": {
          "decision": { "enum": ["ALLOW", "DENY", "REQUEST_REVIEW"] },
          "review_required": { "type": "boolean" },
          "review_can_override": { "type": "boolean" },
          "allowed_reviewer_roles": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "review_can_override": { "const": true } },
              "required": ["review_can_override"]
            },
            "then": { "required": ["allowed_reviewer_roles"] }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
