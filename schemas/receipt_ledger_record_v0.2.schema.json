{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "receipt_ledger_record_v0.2.schema.json",
  "title": "Receipt Ledger Record v0.2",
  "type": "object",
  "required": [
    "schema_version",
    "ledger_record_id",
    "created_at",
    "sequence_number",
    "proposal_id",
    "agent_id",
    "receipt",
    "envelope",
    "verification_errors",
    "tool_result",
    "previous_record_hash",
    "record_hash",
    "tamper_evidence_mode",
    "ledger_auth_version",
    "key_id",
    "record_mac"
  ],
  "properties": {
    "schema_version": { "const": "receipt_ledger_record_v0.2" },
    "ledger_record_id": { "type": "string" },
    "created_at": { "type": "string" },
    "sequence_number": { "type": "integer", "minimum": 1 },
    "proposal_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "receipt": { "type": "object" },
    "envelope": { "type": "object" },
    "verification_errors": { "type": "array", "items": { "type": "string" } },
    "tool_result": { "type": "object" },
    "previous_record_hash": { "type": "string" },
    "record_hash": { "type": "string" },
    "tamper_evidence_mode": { "enum": ["UNKEYED_HASH_CHAIN", "HMAC_SHA256_V1"] },
    "ledger_auth_version": { "enum": ["UNKEYED_HASH_CHAIN_V1", "HMAC_SHA256_V1"] },
    "key_id": { "type": ["string", "null"] },
    "record_mac": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": { "tamper_evidence_mode": { "const": "HMAC_SHA256_V1" } },
        "required": ["tamper_evidence_mode"]
      },
      "then": {
        "properties": {
          "key_id": { "type": "string", "minLength": 1 },
          "record_mac": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "tamper_evidence_mode": { "const": "UNKEYED_HASH_CHAIN" } },
        "required": ["tamper_evidence_mode"]
      },
      "then": {
        "properties": {
          "record_mac": { "type": "null" }
        }
      }
    }
  ],
  "additionalProperties": false
}
